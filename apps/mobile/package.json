{
  "name": "cityconnect-mobile",
  "private": true,
  "version": "0.1.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --dev-client",
    "start:clear": "expo start --dev-client --clear",
    "start:dev-client": "expo start --dev-client --clear",
    "android": "expo run:android",
    "android:dev-client": "expo start --dev-client",
    "android:run": "expo run:android",
    "ios": "expo start --ios",
    "ios:dev-client": "expo start --dev-client",
    "web": "expo start --web",
    "prebuild": "expo prebuild",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "~14.0.4",
    "@tanstack/react-query": "^5.60.5",
    "expo": "^52.0.0",
    "expo-asset": "~11.0.5",
    "expo-constants": "~17.0.8",
    "expo-dev-client": "~5.0.20",
    "expo-font": "~13.0.4",
    "expo-linear-gradient": "~14.0.2",
    "expo-linking": "~7.0.5",
    "expo-router": "^4.0.0",
    "expo-secure-store": "~14.0.1",
    "expo-status-bar": "~2.0.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.9",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-web": "~0.19.13"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "typescript": "5.6.3"
  }
