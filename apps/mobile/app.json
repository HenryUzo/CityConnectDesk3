{
  "expo": {
    "name": "CityConnect",
    "slug": "cityconnect-mobile",
    "scheme": "cityconnect",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "checkAutomatically": "ON_ERROR_RECOVERY",
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "com.cityconnect.mobile"
    },
    "android": {
      "package": "com.cityconnect.mobile"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-asset",
      [
        "expo-dev-client",
        {
          "launchMode": "launcher"
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "projectName": "CityConnect Mobile",
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "ff317b4b-d9f1-4b82-9808-e301887c5335"
      }
    }
  }
}
