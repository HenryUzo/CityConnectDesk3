generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  RESIDENT
  PROVIDER
  ESTATE_ADMIN
  SUPER_ADMIN
  MODERATOR
  SUPPORT
}

enum MembershipStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REJECTED
}

enum AccessType {
  OPEN
  CODE
  DOCUMENT
}

enum ServiceRequestStatus {
  PENDING
  IN_REVIEW
  UNDER_REVIEW
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  REJECTED
}

enum StoreApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OrderStatus {
  PENDING
  PROCESSING
  DELIVERED
  CANCELLED
}

enum TransactionType {
  DEBIT @map("debit")
  CREDIT @map("credit")
  REFUND @map("refund")
  ADJUSTMENT @map("adjustment")
}

enum TransactionStatus {
  PENDING @map("pending")
  COMPLETED @map("completed")
  FAILED @map("failed")
}

enum MaintenancePlanStatus {
  ACTIVE
  CANCELLED
}

enum PaymentStatus {
  UNSET
  PENDING
  PAID
  FAILED
}

enum MaintenancePlanDuration {
  MONTHLY @map("monthly")
  QUARTERLY_3M @map("quarterly_3m")
  HALFYEARLY_6M @map("halfyearly_6m")
  YEARLY @map("yearly")
}

enum AssetCondition {
  NEW @map("new")
  GOOD @map("good")
  FAIR @map("fair")
  POOR @map("poor")
}

enum AssetSubscriptionStatus {
  DRAFT @map("draft")
  PENDING_PAYMENT @map("pending_payment")
  ACTIVE @map("active")
  PAUSED @map("paused")
  EXPIRED @map("expired")
  CANCELLED @map("cancelled")
}

enum MaintenanceScheduleStatus {
  UPCOMING @map("upcoming")
  DUE @map("due")
  ASSIGNED @map("assigned")
  IN_PROGRESS @map("in_progress")
  COMPLETED @map("completed")
  MISSED @map("missed")
  RESCHEDULED @map("rescheduled")
  CANCELLED @map("cancelled")
}

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  phone        String? @unique
  name         String?
  firstName    String? @map("first_name")
  lastName     String? @map("last_name")
  passwordHash String

  globalRole UserRole?

  isApproved Boolean @default(false)
  isActive   Boolean @default(true)

  companyId       String?
  providerCompany Company? @relation("CompanyProviders", fields: [companyId], references: [id])

  memberships Membership[]

  serviceRequestsCreated  ServiceRequest[] @relation("UserServiceRequestsCreated")
  serviceRequestsAssigned ServiceRequest[] @relation("UserServiceRequestsAssigned")

  inspections Inspection[]

  storesOwned      Store[]       @relation("StoreOwner")
  approvedStores   Store[]       @relation("StoreApprovedBy")
  storeMemberships StoreMember[]
  orders           Order[]       @relation("OrderBuyer")

  wallet Wallet?

  ownedCompanies Company[] @relation("CompanyOwner")

  transactions Transaction[]

  auditLogs AuditLog[]

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  storeEstates StoreEstate[]
  assets       Asset[]
  residentAssets            ResidentAsset[]      @relation("MaintenanceResidentAssets")
  maintenanceSubscriptions  AssetSubscription[]  @relation("MaintenanceSubscriptions")
}

model Wallet {
  id        String    @id @default(cuid())
  userId    String    @unique
  user      User      @relation(fields: [userId], references: [id])
  balance   Decimal   @db.Decimal(12, 2) @default("0")
  currency  String    @default("NGN")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  transactions Transaction[]

  @@map("wallets")
}

model Estate {
  id   String @id @default(cuid())
  name String
  slug String @unique

  address String?
  city    String?
  state   String?
  country String?

  accessType AccessType @default(OPEN)
  accessCode String?

  settings Json?
  coverage Json?

  memberships Membership[]

  stores Store[]
  orders Order[]

  serviceRequests ServiceRequest[]

  storeEstates StoreEstate[]

  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  serviceCategories ServiceCategory[]
}

model Membership {
  id        String           @id @default(cuid())
  userId    String
  estateId  String
  role      UserRole
  status    MembershipStatus @default(PENDING)
  isPrimary Boolean          @default(false)

  user   User   @relation(fields: [userId], references: [id])
  estate Estate @relation(fields: [estateId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, estateId, role])
}

model Company {
  id          String  @id @default(cuid())
  name        String
  description String?

  contactEmail String?
  contactPhone String?

  ownerId String
  owner   User   @relation("CompanyOwner", fields: [ownerId], references: [id])

  providers User[] @relation("CompanyProviders")

  stores Store[]

  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ServiceCategory {
  id          String  @id @default(cuid())
  name        String
  description String?
  icon        String?

  scope String?
  tag   String?

  estateId String?
  estate   Estate? @relation(fields: [estateId], references: [id])

  services        Service[]
  serviceRequests ServiceRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Service {
  id          String  @id @default(cuid())
  name        String
  description String?

  categoryId String
  category   ServiceCategory @relation(fields: [categoryId], references: [id])

  serviceRequests ServiceRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ServiceRequest {
  id String @id @default(cuid())

  residentId String
  resident   User   @relation("UserServiceRequestsCreated", fields: [residentId], references: [id])

  estateId String?
  estate   Estate? @relation(fields: [estateId], references: [id])

  serviceCategoryId String?
  serviceCategory   ServiceCategory? @relation(fields: [serviceCategoryId], references: [id])

  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id])

  title       String?
  description String

  preferredStart DateTime?
  preferredEnd   DateTime?

  location  String?
  latitude  Float?
  longitude Float?

  requiresInspection Boolean @default(false)
  adviceMessage      String?

  providerId String?
  provider   User?   @relation("UserServiceRequestsAssigned", fields: [providerId], references: [id])

  status ServiceRequestStatus @default(PENDING)

  billedAmount  Decimal?      @db.Decimal(10, 2)
  paymentStatus PaymentStatus @default(UNSET)

  inspection   Inspection?
  transactions Transaction[]

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  maintenancePlans MaintenancePlan[]
  maintenanceSchedules MaintenanceSchedule[] @relation("MaintenanceScheduleSourceRequest")
}

model Inspection {
  id String @id @default(cuid())

  requestId String         @unique
  request   ServiceRequest @relation(fields: [requestId], references: [id])

  inspectorId String
  inspector   User   @relation(fields: [inspectorId], references: [id])

  scheduledAt DateTime?
  completedAt DateTime?

  findings       String?
  recommendation String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Store {
  id          String  @id @default(cuid())
  name        String
  description String?

  contactEmail String?
  contactPhone String?
  address      String?

  ownerId String
  owner   User   @relation("StoreOwner", fields: [ownerId], references: [id])

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  estateId String?
  estate   Estate? @relation(fields: [estateId], references: [id])

  approvalStatus StoreApprovalStatus @default(PENDING)
  approvedById   String?
  approvedBy     User?               @relation("StoreApprovedBy", fields: [approvedById], references: [id])
  approvedAt     DateTime?

  members       StoreMember[]
  items         MarketplaceItem[]
  orders        Order[]
  deliveryAreas StoreEstate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StoreMember {
  id      String @id @default(cuid())
  storeId String
  userId  String

  role               String?
  canManageInventory Boolean @default(false)
  canManageOrders    Boolean @default(false)

  store Store @relation(fields: [storeId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, userId])
}

model StoreEstate {
  id            String  @id @default(cuid())
  storeId       String
  estateId      String
  allocatedById String?

  store       Store  @relation(fields: [storeId], references: [id])
  estate      Estate @relation(fields: [estateId], references: [id])
  allocatedBy User?  @relation(fields: [allocatedById], references: [id])

  createdAt DateTime @default(now())
}

model ItemCategory {
  id          String  @id @default(cuid())
  name        String
  description String?

  items MarketplaceItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MarketplaceItem {
  id      String @id @default(cuid())
  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  name        String
  description String?

  price    Decimal @db.Decimal(10, 2)
  currency String  @default("NGN")

  unitOfMeasure String?
  stock         Int     @default(0)

  categoryId String?
  category   ItemCategory? @relation(fields: [categoryId], references: [id])

  isActive Boolean @default(true)

  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id      String @id @default(cuid())
  buyerId String
  buyer   User   @relation("OrderBuyer", fields: [buyerId], references: [id])

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  estateId String?
  estate   Estate? @relation(fields: [estateId], references: [id])

  status   OrderStatus @default(PENDING)
  total    Decimal     @db.Decimal(10, 2)
  currency String      @default("NGN")

  deliveryAddress String
  deliveryFee     Decimal? @db.Decimal(10, 2)
  serviceFee      Decimal? @db.Decimal(10, 2)

  paymentMethod String?
  paymentId     String?

  items        OrderItem[]
  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderItem {
  id String @id @default(cuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  itemId String
  item   MarketplaceItem @relation(fields: [itemId], references: [id])

  name     String
  price    Decimal @db.Decimal(10, 2)
  quantity Int

  createdAt DateTime @default(now())
}

model ServicePack {
  id          String  @id @default(cuid())
  name        String
  description String?

  assetType     String
  frequencyDays Int
  price         Decimal? @db.Decimal(10, 2)

  isActive Boolean @default(true)

  assets           Asset[]
  maintenancePlans MaintenancePlan[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Asset {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  name         String?
  assetType    String
  brand        String?
  model        String?
  serialNumber String?

  lastServicedAt DateTime?

  servicePackId String?
  servicePack   ServicePack? @relation(fields: [servicePackId], references: [id])

  maintenancePlans MaintenancePlan[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MaintenancePlan {
  id      String  @id @default(cuid())
  assetId String?
  asset   Asset?  @relation(fields: [assetId], references: [id])

  servicePackId String
  servicePack   ServicePack @relation(fields: [servicePackId], references: [id])

  startDate       DateTime
  nextServiceDate DateTime?
  status          MaintenancePlanStatus @default(ACTIVE)

  lastServiceRequestId String?
  lastServiceRequest   ServiceRequest? @relation(fields: [lastServiceRequestId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MaintenanceCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  icon        String?
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  items MaintenanceItem[]

  @@map("maintenance_categories")
}

model MaintenanceItem {
  id          String   @id @default(cuid())
  categoryId  String   @map("category_id")
  category    MaintenanceCategory @relation(fields: [categoryId], references: [id])
  name        String
  slug        String   @unique
  description String?
  defaultFrequency MaintenancePlanDuration? @map("default_frequency")
  recommendedTasks Json? @map("recommended_tasks")
  imageUrl    String?  @map("image_url")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  residentAssets ResidentAsset[]
  maintenancePlans PreventiveMaintenancePlan[]

  @@index([categoryId])
  @@map("maintenance_items")
}

model ResidentAsset {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  user              User     @relation("MaintenanceResidentAssets", fields: [userId], references: [id])
  maintenanceItemId String   @map("maintenance_item_id")
  maintenanceItem   MaintenanceItem @relation(fields: [maintenanceItemId], references: [id])
  estateId          String?  @map("estate_id")
  customName        String?  @map("custom_name")
  locationLabel     String?  @map("location_label")
  brand             String?
  model             String?
  serialNumber      String?  @map("serial_number")
  purchaseDate      DateTime? @map("purchase_date")
  installedAt       DateTime? @map("installed_at")
  lastServiceDate   DateTime? @map("last_service_date")
  condition         AssetCondition @default(GOOD)
  notes             String?
  metadata          Json?
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  subscriptions AssetSubscription[]

  @@index([userId])
  @@index([maintenanceItemId])
  @@map("resident_assets")
}

model PreventiveMaintenancePlan {
  id                String   @id @default(cuid())
  maintenanceItemId String   @map("maintenance_item_id")
  maintenanceItem   MaintenanceItem @relation(fields: [maintenanceItemId], references: [id])
  name              String
  description       String?
  durationType      MaintenancePlanDuration @map("duration_type")
  price             Decimal  @default("0") @db.Decimal(10, 2)
  currency          String   @default("NGN")
  visitsIncluded    Int      @default(1) @map("visits_included")
  includedTasks     Json?    @map("included_tasks")
  requestLeadDays   Int      @default(3) @map("request_lead_days")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  subscriptions AssetSubscription[]

  @@index([maintenanceItemId])
  @@map("maintenance_plans")
}

model AssetSubscription {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  user              User     @relation("MaintenanceSubscriptions", fields: [userId], references: [id])
  residentAssetId   String   @map("resident_asset_id")
  residentAsset     ResidentAsset @relation(fields: [residentAssetId], references: [id])
  maintenancePlanId String   @map("maintenance_plan_id")
  maintenancePlan   PreventiveMaintenancePlan @relation(fields: [maintenancePlanId], references: [id])
  startDate         DateTime @map("start_date")
  endDate           DateTime? @map("end_date")
  status            AssetSubscriptionStatus @default(DRAFT)
  autoRenew         Boolean  @default(false) @map("auto_renew")
  activatedAt       DateTime? @map("activated_at")
  pausedAt          DateTime? @map("paused_at")
  expiredAt         DateTime? @map("expired_at")
  cancelledAt       DateTime? @map("cancelled_at")
  billingAmount     Decimal  @default("0") @map("billing_amount") @db.Decimal(10, 2)
  currency          String   @default("NGN")
  nextScheduleAt    DateTime? @map("next_schedule_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  schedules MaintenanceSchedule[]

  @@index([userId])
  @@index([residentAssetId])
  @@index([maintenancePlanId])
  @@index([status])
  @@map("asset_subscriptions")
}

model MaintenanceSchedule {
  id             String   @id @default(cuid())
  subscriptionId String   @map("subscription_id")
  subscription   AssetSubscription @relation(fields: [subscriptionId], references: [id])
  scheduledDate  DateTime @map("scheduled_date")
  status         MaintenanceScheduleStatus @default(UPCOMING)
  completedAt    DateTime? @map("completed_at")
  skippedAt      DateTime? @map("skipped_at")
  rescheduledFrom String? @map("rescheduled_from")
  sourceSchedule MaintenanceSchedule? @relation("MaintenanceScheduleReschedule", fields: [rescheduledFrom], references: [id])
  rescheduledSchedules MaintenanceSchedule[] @relation("MaintenanceScheduleReschedule")
  notes          String?
  sourceRequestId String? @map("source_request_id")
  sourceRequest  ServiceRequest? @relation("MaintenanceScheduleSourceRequest", fields: [sourceRequestId], references: [id])
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([subscriptionId])
  @@index([status])
  @@index([scheduledDate])
  @@index([sourceRequestId])
  @@map("maintenance_schedules")
}

model Transaction {
  id String @id @default(cuid())

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  walletId String?
  wallet   Wallet? @relation(fields: [walletId], references: [id])

  amount   Decimal @db.Decimal(14, 2)
  currency String  @default("NGN")

  type   TransactionType
  status TransactionStatus @default(PENDING)

  gateway          String?
  gatewayReference String?

  description String?
  meta        Json?

  serviceRequestId String?
  serviceRequest   ServiceRequest? @relation(fields: [serviceRequestId], references: [id])

  orderId String?
  order   Order?  @relation(fields: [orderId], references: [id])

  originalTransactionId String?
  originalTransaction   Transaction?  @relation("RefundRelation", fields: [originalTransactionId], references: [id])
  refunds               Transaction[] @relation("RefundRelation")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("transactions")
}

model AuditLog {
  id           String  @id @default(cuid())
  userId       String?
  user         User?   @relation(fields: [userId], references: [id])
  action       String
  resourceType String
  resourceId   String?
  details      Json?

  createdAt DateTime @default(now())
}
