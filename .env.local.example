# Copy this file to .env.local and fill values to connect the server to your database
# Example Postgres connection string (replace with your DB):
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Database used by server (Postgres). Required.
DATABASE_URL=

# Optional: API base used by client during development. If omitted, client will
# use same-origin (window.location.origin). Use full URL like http://localhost:5000
VITE_API_URL=

# Other envs you may want to set (secrets, SMTP, etc.)
# SESSION_SECRET=your-secret
# SMTP_URL=smtp://user:pass@smtp.example.com:587
